{
  "name": "vcms",
  "version": "0.1.0",
  "private": true,
  "description": "VCMS — minimal custom CMS engine core.",
  "scripts": {
    "dev": "npm run dev:backend",
    "dev:backend": "tsx watch src/backend/main.ts",
    "dev:admin": "npm --workspace @vcms/admin run dev",
    "migrate": "echo \"Run MySQL migrations from database/migrations/\"",
    "check": "tsc --noEmit",
    "build:admin": "npm --workspace @vcms/admin run build",
    "check:admin": "npm --workspace @vcms/admin run check"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.7",
    "typescript": "latest",
    "tsx": "^4.19.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "frontend/admin"
  ]
}
